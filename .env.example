# Fichier exemple — copier vers `.env.local` (ignoré par git) et remplir les valeurs.
# Toutes les variables préfixées NEXT_PUBLIC_ sont exposées au navigateur ; ne jamais
# y mettre de secret. Pour les secrets serveur, utiliser un préfixe sans NEXT_PUBLIC_.

# --- Firebase ---
# Créer un projet sur https://console.firebase.google.com puis :
# Settings > General > Your apps > Web app > Config
# (Note tech debt : les noms `NEXT_PUBLIC_REACT_APP_*` sont des vestiges d'une
# migration CRA → Next.js — à renommer dans une MR future.)
NEXT_PUBLIC_REACT_APP_apiKey=
NEXT_PUBLIC_REACT_APP_authDomain=
NEXT_PUBLIC_databaseURL=
NEXT_PUBLIC_REACT_APP_projectId=
NEXT_PUBLIC_REACT_APP_storageBucket=
NEXT_PUBLIC_REACT_APP_messagingSenderId=
NEXT_PUBLIC_REACT_APP_appId=
NEXT_PUBLIC_REACT_APP_measurementId=

# --- Stripe ---
# Price ID du produit "achat de partie" (format price_XXXXXXXX)
# Récupérable dans Stripe Dashboard > Products > [le produit] > Pricing.
NEXT_PUBLIC_REACT_APP_stripePriceId=

# --- Google Analytics ---
# Measurement ID GA4 (format G-XXXXXXXXXX) ou ancien Tag ID (UA-XXXXXXXX-X).
# Si vide, le tag GTM n'est pas chargé même avec consentement utilisateur.
NEXT_PUBLIC_GOOGLE_ANALYTICS=

# --- Build ---
# Désactive la génération de source maps en production.
# Hérité de Create React App ; conservé pour compatibilité avec d'éventuels
# outils anciens. Pas indispensable avec Next.js.
GENERATE_SOURCEMAP=false
